      "rule": "ERLAUBT Port 53 TCP/UDP",
      "note": "Nur DNS-Auflösung via AdGuard",
      "vlan_tag": 20
    },
    {
      "from": "SVC",
      "to": "MGMT (NTP)",
      "rule": "ERLAUBT Port 123 UDP",
      "note": "Nur Zeitsynchronisation via Chrony",
      "vlan_tag": 20
    },
    {
      "from": "SVC",
      "to": "MGMT (rest)",
      "rule": "GEBLOCKT",
      "note": "Kein weiterer Zugang zu Management-Infra",
      "vlan_tag": 20
    },
    {
      "from": "LAB",
      "to": "Internet",
      "rule": "ERLAUBT",
      "note": "",
      "vlan_tag": 30
    },
    {
      "from": "LAB",
      "to": "MGMT",
      "rule": "GEBLOCKT",
      "note": "Lab isoliert von Management",
      "vlan_tag": 30
    },
    {
      "from": "LAB",
      "to": "SVC",
      "rule": "GEBLOCKT",
      "note": "Lab isoliert von Services",
      "vlan_tag": 30
    },
    {
      "from": "DMZ",
      "to": "Internet",
      "rule": "ERLAUBT",
      "note": "",
      "vlan_tag": 40
    },
    {
      "from": "DMZ",
      "to": "MGMT",
      "rule": "GEBLOCKT",
      "note": "Kompromittierte DMZ-Dienste kein MGMT-Zugang",
      "vlan_tag": 40
    },
    {
      "from": "DMZ",
      "to": "SVC",
      "rule": "GEBLOCKT",
      "note": "Kompromittierte DMZ-Dienste kein SVC-Zugang",
      "vlan_tag": 40
    },
    {
      "from": "DMZ",
      "to": "LAB",
      "rule": "GEBLOCKT",
      "note": "DMZ komplett isoliert von internen Netzen",
      "vlan_tag": 40
    },
    {
      "from": "LAN (alle)",
