 {
  "id": "p3-dokuwiki",
  "title": "DokuWiki",
  "status": "done",
  "tags": ["Wiki", "DokuWiki", "Apache", "PHP", "Dokumentation", "Self-hosted"],
  "desc": "DokuWiki als interne Wissensdatenbank im SVC-VLAN (10.0.2.11). Dateibasiert, kein SQL. Erreichbar unter wiki.mynooblab.dev via Caddy Reverse Proxy mit TLS. Namespaces fuer Infrastruktur, Netzwerk, Dienste, Security, Runbooks.",
  "notes": "Apache2 + PHP als Application Server. Caddy terminiert TLS, leitet HTTP an 10.0.2.11:80 weiter. ACL Closed Wiki, Superuser landvogt. install.php geloescht.",
  "details": {
    "container": {
      "id": 108,
      "type": "LXC (unprivileged)",
      "hostname": "dokuwiki",
      "ip": "10.0.2.11/24",
      "gw": "10.0.2.1",
      "os": "Debian 13",
      "ram_mb": 512,
      "disk_gb": 8,
      "cores": 1,
      "vlan_tag": 20,
      "onboot": true,
      "startup_order": 5
    },
    "stack": {
      "webserver": "Apache2 (Application Server, Port 80)",
      "php": "PHP 8.x + xml + gd + mbstring",
      "dokuwiki": "DokuWiki stable",
      "data_dir": "/var/www/dokuwiki/data",
      "config_dir": "/var/www/dokuwiki/conf"
    },
    "access": {
      "url": "https://wiki.mynooblab.dev",
      "reverse_proxy": "Caddy (10.0.2.10) → Apache (10.0.2.11:80)",
      "dns": "AdGuard Rewrite *.mynooblab.dev → 10.0.2.10",
      "vpn_only": true
    },
    "security_notes": [
      "Closed Wiki — nur registrierte User koennen lesen/schreiben",
      "Keine Selbstregistrierung — User werden manuell angelegt",
      "install.php nach Setup geloescht — verhindert Admin-Takeover",
      "Apache denied /data und /conf Verzeichnisse — keine Rohdaten-Exposition",
      "TLS-Terminierung am Caddy, Klartext nur innerhalb SVC-VLAN",
      "Unprivileged LXC — Container-Breakout gibt keine Host-Rechte",
      "SSH Key-only, Root-Login deaktiviert"
    ]
  },
  "log": [
    {"date": "2026-04-29", "entry": "CT108 erstellt: dokuwiki, SVC-VLAN Tag 20, 10.0.2.11/24, unprivileged, 512 MB RAM, 8 GB Disk."},
    {"date": "2026-04-29", "entry": "Hardening: landvogt, SSH Key-only, Root off. Apache2 + PHP + DokuWiki stable installiert."},
    {"date": "2026-04-29", "entry": "Apache Security: /data und /conf denied. Caddy wiki.mynooblab.dev → 10.0.2.11:80."},
    {"date": "2026-04-29", "entry": "OPNsense: VPN-zu-SVC Regel (10.0.5.0/24 → 10.0.2.0/24) hinzugefuegt."},
    {"date": "2026-04-29", "entry": "DokuWiki Setup via Installer. Closed Wiki, Superuser landvogt, install.php geloescht."},
    {"date": "2026-04-29", "entry": "Startseite mit 6 Namespaces erstellt. Step DONE."}
  ],
  "deferred_reason": ""
